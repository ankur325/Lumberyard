{
  "name": "lumberyard",
  "version": "0.1.0",
  "private": true,
  "description": "Local React app for viewing AWS CloudWatch logs with saved loggers, filtering, and live tail.",
  "license": "MIT",
  "keywords": [
    "aws",
    "cloudwatch",
    "logs",
    "log-viewer",
    "react",
    "live-tail"
  ],
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace web && npm run build --workspace server",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
